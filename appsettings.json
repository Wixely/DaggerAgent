{
  "Agent": {
    "SystemPrompt": "You are DaggerAgent, a focused LLM coding/task agent.",
    "SummariserModel": "",
    "MaxContextTokens": 120000,
    "CompressionThreshold": 90000,
    "CompressionKeepLastTurns": 6,
    "MaxTurnsPerInvocation": 25,
    "MaxSubAgentDepth": 3,
    "MaxTurnsPerSubAgent": 10,
    "HideThinkingFromHistory": true,
    "ShowThinking": true,
    "ShowTurnStats": true,
    "VerboseTurnStats": false,
    "ShowToolCalls": true,
    "AutoContinueOnIncomplete": true,
    "MaxAutoContinues": 2
  },
  "OpenAI": {
    "BaseUrl": "http://localhost:1234/v1",
    "ApiKey": "",
    "DefaultModel": "qwen3.5:122b",
    "RequestTimeoutSeconds": 600
  },
  "Mcp": {
    "Servers": []
  },
  "Server": {
    "Host": "0.0.0.0",
    "Port": 5090,
    "Path": "/agent"
  },
  "Jobs": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=data/jobs.db"
  },
  "Tools": {
    "WorkingDirectory": "",
    "AllowAnyPath": false,
    "ReadOnly": false,
    "AllowWrite": false,
    "WritePreview": false,
    "AllowShell": false,
    "MaxFileBytes": 5242880,
    "MaxResults": 200,
    "ShellTimeoutSeconds": 60,
    "GranularTools": false,
    "ForcePlan": true,
    "ReadFileSummaryThresholdBytes": 50000
  },
  "Web": {
    "AllowPrivateNetworks": false,
    "MaxResponseBytes": 5242880,
    "MaxTimeoutSeconds": 60,
    "AllowedHostPatterns": [],
    "BlockedHostPatterns": []
  },
  "Auth": {
    "HeaderName": "X-Api-Key",
    "ApiKeys": [],
    "BypassPaths": [ "/", "/favicon.ico", "/agent/healthz", "/api/version", "/v1/models" ]
  },
  "Triggers": {
    "Enabled": false,
    "PollIntervalSeconds": 120,
    "Phrase": "@dagger",
    "AllowedAuthors": [],
    "MaxJobsPerCycle": 5,
    "JobPreamble": "You were triggered by a mention in a ticket. Read the details below, decide whether you can act on them, and proceed.",
    "Sources": []
  },
  "Memory": {
    "Enabled": false,
    "EmbeddingModel": "text-embedding-3-small",
    "MaxRecallResults": 5,
    "SimilarityFloor": 0.45
  },
  "Pricing": {
    "Models": {
      "gpt-4o": { "InputPerMillion": 2.50, "OutputPerMillion": 10.00 },
      "gpt-4o-mini": { "InputPerMillion": 0.15, "OutputPerMillion": 0.60 },
      "gpt-4.1": { "InputPerMillion": 2.00, "OutputPerMillion": 8.00 },
      "gpt-4.1-mini": { "InputPerMillion": 0.40, "OutputPerMillion": 1.60 },
      "claude-opus-4-7": { "InputPerMillion": 15.00, "OutputPerMillion": 75.00 },
      "claude-sonnet-4-6": { "InputPerMillion": 3.00, "OutputPerMillion": 15.00 },
      "claude-haiku-4-5": { "InputPerMillion": 1.00, "OutputPerMillion": 5.00 }
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dagger-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
